# =============================================================================
#  Mapping stylet Huion multi-écran — configuration
#  Surchargeable par l'environnement : KAMVAS_OUTPUT=DP-2 ./install.sh
# =============================================================================

# Écran cible du stylet (nom de sortie xrandr : HDMI-0, DP-2, DP-5, …).
# Liste : xrandr --listmonitors
KAMVAS_OUTPUT="${KAMVAS_OUTPUT:-HDMI-0}"
